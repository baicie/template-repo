{
  "$schema": "https://json.schemastore.org/electron-builder",
  "appId": "com.electron.app",
  "productName": "ElectronApp",
  "directories": {
    "output": "release",
    "buildResources": "build"
  },
  "files": [
    "apps/main/out/**",
    "apps/preload/dist/**",
    "apps/renderer/dist/**"
  ],
  "extraMetadata": {
    "main": "apps/main/out/main/index.js",
    "version": "1.0.0"
  },
  "electronVersion": "41.2.0",
  "asar": false,
  "asarUnpack": [
    "**/node_modules/@electron/**/*",
    "**/node_modules/native-addon/**/*",
    "**/node_modules/*.node",
    "**/node_modules/@msgpack/**/*"
  ],
  "compression": "maximum",
  "npmRebuild": false,
  "nodeGypRebuild": false,
  "buildDependenciesFromSource": false,
  "electronDownload": {
    "mirror": "https://npmmirror.com/mirrors/electron/"
  },
  "mac": {
    "target": [
      {
        "target": "dmg",
        "arch": ["x64", "arm64"]
      }
    ],
    "category": "public.app-category.developer-tools",
    "artifactName": "${productName}-${version}-mac-${arch}.${ext}",
    "hardenedRuntime": true,
    "gatekeeperAssess": false
  },
  "win": {
    "target": [
      {
        "target": "portable",
        "arch": ["x64"]
      }
    ],
    "artifactName": "${productName}-${version}-win-${arch}.${ext}"
  },
  "linux": {
    "target": [
      {
        "target": "AppImage",
        "arch": ["x64"]
      }
    ],
    "category": "Development",
    "artifactName": "${productName}-${version}-linux-${arch}.${ext}"
  },
  "portable": {
    "artifactName": "${productName}-${version}-portable.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true
  },
  "appx": {
    "displayName": "ElectronApp",
    "identityName": "ElectronApp",
    "publisher": "CN=ElectronApp",
    "publisherDisplayName": "ElectronApp",
    "applicationId": "ElectronApp"
  },
  "publish": null
}
