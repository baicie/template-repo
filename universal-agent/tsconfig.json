{
  "extends": ["./scripts/tsconfig.base.json"],
  "compilerOptions": {
    "paths": {
      "@agent/core": ["./packages/core/src/index.ts"],
      "@agent/core/*": ["./packages/core/src/*"]
    },
    "types": ["node", "vitest/globals"],
    "noEmit": true
  },
  "include": ["apps/**/*", "packages/**/*", "scripts/**/*"],
  "exclude": ["**/dist", "**/node_modules", "**/temp"]
}
