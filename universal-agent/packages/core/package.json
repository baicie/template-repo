{
  "name": "@agent/core",
  "type": "module",
  "version": "0.1.0",
  "description": "Universal Agent Runtime - core library",
  "license": "MIT",
  "keywords": ["agent", "ai", "runtime", "tool", "skill"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
