{
  "name": "vscode-ext",
  "displayName": "VSCode Extension",
  "description": "A VSCode extension in monorepo",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vscode-ext.helloWorld",
        "title": "Hello World"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "tsc -b",
    "watch": "tsc -b -w",
    "package": "vsce package",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "18.x",
    "typescript": "^5.3.3",
    "@repo/tsconfig": "workspace:*"
  },
  "dependencies": {
    "@repo/utils": "workspace:*"
  }
}
